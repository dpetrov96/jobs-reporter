{
  "name": "jobs-reporter",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @jobs-reporter/web",
    "build:web": "npm run build -w @jobs-reporter/web",
    "build:backend": "npm run build -w @jobs-reporter/backend",
    "deploy:backend": "npm run deploy:code -w @jobs-reporter/backend",
    "deploy:web:ec2": "bash scripts/deploy-web-ec2.sh"
  }
}
