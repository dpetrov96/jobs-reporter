# Email — pick one provider via EMAIL_PROVIDER

# resend (recommended for local dev)
# - Sign up at https://resend.com
# - Free tier: 100 emails/day
# - Test sender: onboarding@resend.dev (no domain setup needed)
# - Copy API key from dashboard
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=LinkedIn Finder <onboarding@resend.dev>

# ses (native AWS — better for production all-in-AWS)
# - Verify domain or email in AWS SES Console
# - Sandbox: can only send TO verified addresses
# - Lambda needs IAM ses:SendEmail (already in template when EmailProvider=ses)
# EMAIL_PROVIDER=ses
# EMAIL_FROM=LinkedIn Finder <noreply@yourdomain.com>

# Recipient for job reports and ?sendTest=true health checks
REPORT_EMAIL_TO=you@example.com

APP_STAGE=dev

# GitHub Actions — shared
# RESEND_API_KEY=re_...                    # deploy success/failure emails (both workflows)
# DEPLOY_NOTIFY_EMAIL=dimitar@dimitar.ai   # repository variable (optional)

# GitHub Actions — backend deploy (secrets)
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY

# GitHub Actions — web EC2 deploy (secrets)
# EC2_HOST=1.2.3.4
# EC2_USER=ubuntu
# EC2_SSH_KEY=<private key PEM contents>

# GitHub Actions — repository variables (optional)
# AWS_REGION=eu-central-1
# STACK_PREFIX=lambda-linkedin-finder
# VITE_API_URL=https://z8q1cuu3g3.execute-api.eu-central-1.amazonaws.com
# WEB_URL=http://63.181.35.55
# EC2_DEPLOY_PATH=/var/www/jobs-reporter
# EMAIL_FROM=LinkedIn Finder <onboarding@resend.dev>

# Monorepo
# npm run dev:web
# npm run deploy:backend
# npm run deploy:web:ec2
# JOB_COUNTRIES=BG,FR,DE,NL,GB,BE,PL  (or all for full EU registry)
# SCRAPE_REGION=europe  (or usa for US-only scraper)
# US scraper runs 9 AM–11 PM LA time via FetchJobsUsFunction (see template.yaml)

# OpenAI (market analyses AI recommendations)
# Stored in AWS SSM — survives sam deploy. Set once on your machine:
#   OPENAI_API_KEY='sk-...' bash scripts/set-openai-key.sh
# Default SSM path: /lambda-linkedin-finder/openai-api-key
# OPENAI_API_KEY_PARAM=/lambda-linkedin-finder/openai-api-key
