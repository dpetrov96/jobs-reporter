# Email — pick one provider via EMAIL_PROVIDER

# resend (recommended for local dev)
# - Sign up at https://resend.com
# - Free tier: 100 emails/day
# - Test sender: onboarding@resend.dev (no domain setup needed)
# - Copy API key from dashboard
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=LinkedIn Finder <onboarding@resend.dev>

# ses (native AWS — better for production all-in-AWS)
# - Verify domain or email in AWS SES Console
# - Sandbox: can only send TO verified addresses
# - Lambda needs IAM ses:SendEmail (already in template when EmailProvider=ses)
# EMAIL_PROVIDER=ses
# EMAIL_FROM=LinkedIn Finder <noreply@yourdomain.com>

# Recipient for job reports and ?sendTest=true health checks
REPORT_EMAIL_TO=you@example.com

APP_STAGE=dev

# GitHub Actions (Repository secrets)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Optional repository variables:
# AWS_REGION=eu-central-1
# STACK_PREFIX=lambda-linkedin-finder
